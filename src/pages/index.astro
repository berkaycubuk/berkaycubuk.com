---
import IndexLayout from '../layouts/IndexLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import moment from 'moment';
import { projects } from '../data/projects';

const blogPosts = await getCollection('writings');
const recentPosts = blogPosts
  .sort((a, b) => moment(b.data.date).valueOf() - moment(a.data.date).valueOf())
  .slice(0, 5);

const recentProjects = projects.slice(0, 3);

const bookingUrl = "https://cal.com/berkaycubuk/discovery-call";

const services = [
  {
    title: "Order & inventory systems",
    body: "Replace your Shopify-app + spreadsheet stack with one system that tracks orders, syncs inventory, and alerts you before stockouts.",
  },
  {
    title: "Custom dashboards & reporting",
    body: "Pull data from Shopify, ad platforms, and fulfillment into one real-time dashboard. No more copying numbers between tabs.",
  },
  {
    title: "Workflow automation",
    body: "Automate returns processing, customer tagging, fulfillment routing — whatever manual process is eating your team's hours.",
  },
];

const fitFor = [
  "DTC brands spending hours on manual processes that should be automated.",
  "Shopify store owners duct-taping 5+ apps to do what one tool should.",
  "Growing teams who need custom software but don't want to hire a dev team.",
];

const process = [
  { step: "1", title: "20-min discovery call", body: "Problem defined and potential solutions disgussed." },
  { step: "2", title: "Proposal", body: "You get scoped and clearly defined proposal from me." },
  { step: "3", title: "Build & ship", body: "You get constant updates about the progress. No surpises at the end." },
  { step: "4", title: "Handoff", body: "Code, docs, deploy instructions etc.. everything will be delivered to you." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Berkay Çubuk — I Build Software That Replaces Your Spreadsheets",
  "url": "https://berkaycubuk.com",
  "author": {
    "@type": "Person",
    "name": "Berkay Cubuk",
    "url": "https://berkaycubuk.com/about"
  },
  "description": "I replace your Shopify-app + Zapier + spreadsheet stack with one custom system you own. Built in 3 weeks."
};
---
<IndexLayout
  title="Berkay Cubuk — I Build Software That Replaces Your Spreadsheets"
  description="I replace your Shopify-app + Zapier + spreadsheet stack with one custom system you own. Built in 3 weeks."
  jsonLd={jsonLd}
>
  <Hero />

  <!--
  <section class="pb-12">
    <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">Who this is for</h2>
    <ul class="flex flex-col gap-2">
      {fitFor.map(line => (
        <li class="flex gap-3 text-[var(--color-text-secondary)]">
          <span class="text-[var(--color-accent)] shrink-0">→</span>
          <span>{line}</span>
        </li>
      ))}
    </ul>
  </section>
  -->

  <section id="work" class="pb-12 scroll-mt-20">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-xl font-semibold text-[var(--color-text)]">Recent work</h2>
      <a href="/projects" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="flex flex-col gap-4">
      {recentProjects.map(project => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          links={project.links}
        />
      ))}
    </div>
  </section>

  <section class="pb-12">
    <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">What I build</h2>
    <div class="flex flex-col gap-4">
      {services.map(s => (
        <div class="border border-[var(--color-card-border)] rounded-xl p-5 bg-[var(--color-card-bg)]">
          <h3 class="text-base font-semibold text-[var(--color-text)]">{s.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-text-secondary)]">{s.body}</p>
        </div>
      ))}
    </div>
    <!--
    <p class="mt-4 text-sm text-[var(--color-text-tertiary)]">
      All in Go — fast, single binary, no Python dependency hell, cheap to host.
    </p>
    -->
  </section>

  <section class="pb-12">
    <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">How I work</h2>
    <ol class="flex flex-col gap-4">
      {process.map(p => (
        <li class="flex gap-4">
          <span class="shrink-0 w-7 h-7 rounded-full bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-secondary)] text-sm font-medium flex items-center justify-center">
            {p.step}
          </span>
          <div>
            <h3 class="text-base font-semibold text-[var(--color-text)]">{p.title}</h3>
            <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{p.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="full-bleed bg-[var(--color-bg-secondary)] border-y border-[var(--color-border)] my-12 py-16">
    <div class="max-w-[720px] mx-auto px-6 text-center">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-medium mb-3">
        Let's talk
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3">
        Have a problem worth a<br />20-minute conversation?
      </h2>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto">
        Grab a free 20-minute slot on my calendar. We'll talk through your problem and figure out if it's a fit.
      </p>
      <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-block px-6 py-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors">
        Book a call &rarr;
      </a>
    </div>
  </section>

  <section class="pb-8">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-xl font-semibold text-[var(--color-text)]">Recent writings</h2>
      <a href="/writings" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="flex flex-col">
      {recentPosts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={moment(post.data.date).format('MMM DD, YYYY')}
          href={'/' + moment(post.data.date).format('YYYY/MM/DD') + '/' + post.slug}
          compact
        />
      ))}
    </div>
  </section>
</IndexLayout>
