---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import moment from 'moment';

const blogPosts = await getCollection('writings');
const sortedPosts = blogPosts.sort((a, b) => moment(b.data.date).valueOf() - moment(a.data.date).valueOf());

const nav = [
  { label: 'Writings', href: '/writings', active: true },
  { label: 'Projects', href: '/projects' },
  { label: 'Tools', href: '/tools' },
  { label: 'About', href: '/about' },
];
---
<BaseLayout
  title="Writings — Berkay Çubuk"
  description="One of the greatest things about humans is that we can express our thoughts and type them into text."
>
  <main id="stage" class="stage">
    <header class="chrome">
      <a href="/" class="floaty brand" data-role="brand">Berkay Çubuk</a>
      <nav class="chrome">
        {nav.map(n => (
          <a href={n.href} class={`floaty nav-link ${n.active ? 'active' : ''}`} data-role="nav">{n.label}</a>
        ))}
      </nav>
    </header>

    <h1 class="floaty title" data-role="title">Writings</h1>
    <p class="floaty intro" data-role="intro">
      One of the greatest things about humans is that we can express our thoughts and type them into text.
    </p>

    {sortedPosts.map((post: any) => (
      <a
        href={'/' + moment(post.data.date).format('YYYY/MM/DD') + '/' + post.slug}
        class="floaty post-card"
        data-role="card"
      >
        <div class="post-head">
          <h2 class="post-title">{post.data.title}</h2>
          <time class="post-date">{moment(post.data.date).format('MMM DD, YYYY')}</time>
        </div>
        {post.data.description && (
          <p class="post-desc">{post.data.description}</p>
        )}
      </a>
    ))}

    <button id="theme-toggle" type="button" aria-label="Toggle dark mode" class="toggle">
      <svg class="icon-sun" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg class="icon-moon" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
  </main>
</BaseLayout>

<style>
  /* Monochrome palette — same language as the home page; inverts under .dark. */
  :global(html body) {
    background-color: #ffffff;
  }
  :global(html.dark body) {
    background-color: #111111;
  }

  .stage {
    --fg: #000000;
    --fg-dim: #666666;
    --card-bg: #f2f2f2;
    --card-bg-hover: #ebebeb;
    --card-desc: #333333;
    position: relative;
    flex: 1;
    width: 100%;
    overflow-x: hidden;
    color: var(--fg);
  }
  :global(html.dark) .stage {
    --fg: #f0f0f0;
    --fg-dim: #8a8a8a;
    --card-bg: #1c1c1c;
    --card-bg-hover: #242424;
    --card-desc: #b4b4b4;
  }

  /* Wrappers keep <header>/<nav> semantics but generate no box, so their
     children position freely against the stage. */
  .chrome {
    display: contents;
  }

  .floaty {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
    will-change: transform;
  }
  .stage.ready .floaty {
    opacity: 1;
    transition: opacity 0.5s ease;
  }
  .floaty.dragging {
    cursor: grabbing;
  }

  /* Header chrome — brand + nav links, each floating */
  .brand {
    font-family: 'Rock Salt', cursive;
    font-weight: 400;
    font-size: 15px;
    white-space: nowrap;
    color: var(--fg);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .brand:hover {
    color: var(--fg-dim);
  }
  .nav-link {
    font-size: 14px;
    white-space: nowrap;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover {
    color: var(--fg);
  }
  .nav-link.active {
    color: var(--fg);
  }

  /* Title + intro, also floating */
  .title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    white-space: nowrap;
    color: var(--fg);
  }
  .intro {
    margin: 0;
    max-width: min(46ch, calc(100vw - 40px));
    color: var(--fg-dim);
  }

  /* Post cards — gray, floating */
  .post-card {
    width: 300px;
    max-width: calc(100vw - 40px);
    padding: 18px 20px;
    background-color: var(--card-bg);
    border-radius: 12px;
    text-decoration: none;
    color: var(--fg);
    transition: background-color 0.15s ease;
  }
  .post-card:hover {
    background-color: var(--card-bg-hover);
  }
  .post-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .post-title {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--fg);
  }
  .post-date {
    flex-shrink: 0;
    font-size: 13px;
    color: var(--fg-dim);
  }
  .post-desc {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.5;
    color: var(--card-desc);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Theme toggle — floats around the screen (fixed to the viewport, draggable),
     starting bottom-right. JS sets left/top. */
  .toggle {
    position: fixed;
    left: 0;
    top: 0;
    padding: 8px;
    border: none;
    background: none;
    line-height: 0;
    cursor: grab;
    color: var(--fg);
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
    will-change: transform;
    transition: color 0.15s ease;
  }
  .toggle:hover {
    color: var(--fg-dim);
  }
  .toggle.dragging {
    cursor: grabbing;
  }
  .toggle svg {
    display: block;
  }
  :global(html.dark) .toggle .icon-moon {
    display: none;
  }
  :global(html:not(.dark)) .toggle .icon-sun {
    display: none;
  }
</style>

<script>
  const stage = document.getElementById('stage')!;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // On touch ("mobile") devices, dragging the floating elements fights with
  // scrolling — so disable drag + drift here and let the page scroll normally.
  const noDrag = window.matchMedia('(pointer: coarse)').matches;

  // Every element on the page floats freely and can be dragged anywhere — the
  // same fluid motion as the home page. Chrome (brand, nav, title, intro) sits
  // in a top band; the post cards scatter across a loose grid below it. Drag
  // positions live only for the session — never persisted.
  const items = Array.from(stage.querySelectorAll<HTMLElement>('.floaty')).map(el => ({
    el,
    role: el.dataset.role || 'card',
    jitterX: Math.random() * 2 - 1,
    jitterY: Math.random() * 2 - 1,
    ampX: reduceMotion ? 0 : 3 + Math.random() * 6,
    ampY: reduceMotion ? 0 : 3 + Math.random() * 6,
    speed: 0.00025 + Math.random() * 0.0004,
    phase: Math.random() * Math.PI * 2,
    fx: 0,
    fy: 0,
    anchorX: 0,
    anchorY: 0,
    dragging: false,
  }));

  // The theme toggle floats around the screen too — fixed to the viewport so it
  // never scrolls away, draggable, and drifting. Starts pinned bottom-right.
  const toggle = document.getElementById('theme-toggle')!;
  const toggleState = {
    ampX: reduceMotion ? 0 : 3 + Math.random() * 5,
    ampY: reduceMotion ? 0 : 3 + Math.random() * 5,
    speed: 0.00025 + Math.random() * 0.0004,
    phase: Math.random() * Math.PI * 2,
    fx: 0,
    fy: 0,
    x: 0,
    y: 0,
    placed: false, // becomes true once the user drags it
    dragging: false,
  };

  function placeToggle() {
    if (toggleState.dragging || toggleState.placed) return;
    const m = 28;
    toggleState.x = window.innerWidth - m - toggle.offsetWidth;
    toggleState.y = window.innerHeight - m - toggle.offsetHeight;
    toggle.style.left = toggleState.x + 'px';
    toggle.style.top = toggleState.y + 'px';
  }

  // Touch devices: re-enable native scrolling + text selection on the floaty
  // elements (the .floaty rule disables them so dragging works on desktop).
  if (noDrag) {
    for (const it of [...items, { el: toggle }]) {
      it.el.style.touchAction = 'auto';
      it.el.style.cursor = 'auto';
      it.el.style.setProperty('user-select', 'auto');
      it.el.style.setProperty('-webkit-user-select', 'auto');
    }
  }

  let zTop = 10;

  function clamp(v: number, min: number, max: number) {
    return Math.max(min, Math.min(max, v));
  }

  function setAnchor(it: typeof items[number], x: number, y: number) {
    if (it.dragging) return;
    it.anchorX = x;
    it.anchorY = y;
    it.el.style.left = x + 'px';
    it.el.style.top = y + 'px';
  }

  function layout() {
    const w = stage.clientWidth;
    const mobile = w < 640;
    const pad = mobile ? 22 : 40;

    // --- top chrome band ---
    const rowY = mobile ? 30 : 46;
    const brand = items.find(it => it.role === 'brand');
    const navItems = items.filter(it => it.role === 'nav');
    const title = items.find(it => it.role === 'title');
    const intro = items.find(it => it.role === 'intro');

    if (brand) setAnchor(brand, pad + brand.el.offsetWidth / 2, rowY);

    // Nav links flow in from the right edge. On mobile they drop to their own
    // row so the (wide) handwritten brand doesn't overlap them.
    const navY = mobile ? rowY + 36 : rowY;
    let xr = w - pad;
    for (let k = navItems.length - 1; k >= 0; k--) {
      const it = navItems[k];
      setAnchor(it, xr - it.el.offsetWidth / 2, navY);
      xr -= it.el.offsetWidth + (mobile ? 12 : 22);
    }

    // Title + intro, stacked by measured height so they never overlap. The intro
    // gets an explicit width so its absolute box isn't shrink-wrapped narrow.
    const titleTop = navY + (mobile ? 40 : 64);
    const titleY = titleTop + (title ? title.el.offsetHeight / 2 : 0);
    if (title) setAnchor(title, pad + title.el.offsetWidth / 2, titleY);

    if (intro) intro.el.style.width = Math.min(520, w - 2 * pad) + 'px';
    const introTop = titleY + (title ? title.el.offsetHeight / 2 : 0) + (mobile ? 14 : 16);
    const introY = introTop + (intro ? intro.el.offsetHeight / 2 : 0);
    if (intro) setAnchor(intro, pad + intro.el.offsetWidth / 2, introY);

    const cardsTop = introY + (intro ? intro.el.offsetHeight / 2 : 0) + (mobile ? 36 : 60);

    // --- cards ---
    const cardItems = items.filter(it => it.role === 'card');

    if (mobile) {
      // Clean, full-width single column stacked by measured height — no scatter
      // or jitter (which clipped cards against the screen edge).
      const cardW = w - 2 * pad;
      const gap = 14;
      let y = cardsTop;
      for (const it of cardItems) {
        it.el.style.width = cardW + 'px';
        const h = it.el.offsetHeight;
        setAnchor(it, w / 2, y + h / 2);
        y += h + gap;
      }
      stage.style.minHeight = y + 40 + 'px';
    } else {
      // Scattered grid on wider screens.
      const cardW = Math.min(300, w - 2 * pad);
      const cols = Math.max(1, Math.floor(w / (cardW + 56)));
      const n = cardItems.length;
      const rows = Math.max(1, Math.ceil(n / cols));
      const availH = Math.max(360, window.innerHeight - stage.getBoundingClientRect().top - cardsTop - 24);
      const cellW = w / cols;
      const cellH = Math.max(168, availH / rows);
      stage.style.minHeight = cardsTop + cellH * rows + 24 + 'px';

      cardItems.forEach((it, i) => {
        const row = Math.floor(i / cols);
        const posInRow = i - row * cols;
        const itemsInRow = row === rows - 1 ? n - cols * (rows - 1) : cols;
        const rowPad = (cols - itemsInRow) / 2; // center a partial last row
        let ax = cellW * (posInRow + rowPad + 0.5) + it.jitterX * cellW * 0.16;
        const ay = cardsTop + cellH * (row + 0.5) + it.jitterY * cellH * 0.18;
        ax = clamp(ax, cardW / 2 + 12, w - cardW / 2 - 12);
        setAnchor(it, ax, ay);
      });
    }
  }

  layout();
  placeToggle();
  // Re-run once fonts settle, since chrome positions depend on text widths.
  if (document.fonts?.ready) document.fonts.ready.then(layout);
  window.addEventListener('load', layout);

  // Continuous, organic drift — the "fluid" idle motion of the home page.
  function frame(t: number) {
    for (const it of items) {
      if (!it.dragging) {
        it.fx = Math.sin(t * it.speed + it.phase) * it.ampX;
        it.fy = Math.cos(t * it.speed * 0.9 + it.phase) * it.ampY;
      }
      it.el.style.transform =
        `translate(-50%, -50%) translate(${it.fx.toFixed(2)}px, ${it.fy.toFixed(2)}px)`;
    }
    if (!toggleState.dragging) {
      toggleState.fx = Math.sin(t * toggleState.speed + toggleState.phase) * toggleState.ampX;
      toggleState.fy = Math.cos(t * toggleState.speed * 0.9 + toggleState.phase) * toggleState.ampY;
    }
    toggle.style.transform = `translate(${toggleState.fx.toFixed(2)}px, ${toggleState.fy.toFixed(2)}px)`;
    requestAnimationFrame(frame);
  }
  if (noDrag) {
    // Static: keep the centering transform, skip the drift animation.
    for (const it of items) it.el.style.transform = 'translate(-50%, -50%)';
  } else {
    requestAnimationFrame(frame);
  }

  requestAnimationFrame(() => stage.classList.add('ready'));

  // Dragging via pointer events (works for mouse + touch). Disabled on touch
  // devices so the page scrolls normally.
  if (!noDrag) for (const it of items) {
    let startPX = 0, startPY = 0, startAX = 0, startAY = 0, moved = false;

    it.el.addEventListener('pointerdown', (e) => {
      it.dragging = true;
      moved = false;
      startPX = e.clientX;
      startPY = e.clientY;
      startAX = it.anchorX;
      startAY = it.anchorY;
      it.el.classList.add('dragging');
      it.el.style.zIndex = String(++zTop);
      it.el.setPointerCapture(e.pointerId);
      e.preventDefault();
    });

    it.el.addEventListener('pointermove', (e) => {
      if (!it.dragging) return;
      const dx = e.clientX - startPX;
      const dy = e.clientY - startPY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) moved = true;
      it.anchorX = clamp(startAX + dx, 40, stage.clientWidth - 40);
      it.anchorY = clamp(startAY + dy, 40, stage.scrollHeight - 40);
      it.el.style.left = it.anchorX + 'px';
      it.el.style.top = it.anchorY + 'px';
    });

    function end() {
      if (!it.dragging) return;
      it.dragging = false;
      it.el.classList.remove('dragging');
    }

    it.el.addEventListener('pointerup', end);
    it.el.addEventListener('pointercancel', end);

    // A drag shouldn't also fire the element's navigation.
    it.el.addEventListener('click', (e) => {
      if (moved) e.preventDefault();
    });
  }

  // Theme toggle — draggable within the viewport (fixed), click toggles theme.
  // Dragging is disabled on touch devices; the click still toggles the theme.
  {
    let tsx = 0, tsy = 0, tax = 0, tay = 0, tmoved = false;

    if (!noDrag) {
      toggle.addEventListener('pointerdown', (e) => {
        toggleState.dragging = true;
        toggleState.placed = true; // stop auto-repositioning once moved
        tmoved = false;
        tsx = e.clientX;
        tsy = e.clientY;
        tax = toggleState.x;
        tay = toggleState.y;
        toggle.classList.add('dragging');
        toggle.setPointerCapture(e.pointerId);
        e.preventDefault();
      });

      toggle.addEventListener('pointermove', (e) => {
        if (!toggleState.dragging) return;
        const dx = e.clientX - tsx;
        const dy = e.clientY - tsy;
        if (Math.abs(dx) > 3 || Math.abs(dy) > 3) tmoved = true;
        toggleState.x = clamp(tax + dx, 4, window.innerWidth - toggle.offsetWidth - 4);
        toggleState.y = clamp(tay + dy, 4, window.innerHeight - toggle.offsetHeight - 4);
        toggle.style.left = toggleState.x + 'px';
        toggle.style.top = toggleState.y + 'px';
      });

      function tend() {
        if (!toggleState.dragging) return;
        toggleState.dragging = false;
        toggle.classList.remove('dragging');
      }

      toggle.addEventListener('pointerup', tend);
      toggle.addEventListener('pointercancel', tend);
    }

    toggle.addEventListener('click', () => {
      if (tmoved) return;
      const isDark = document.documentElement.classList.toggle('dark');
      try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch { /* ignore */ }
    });
  }

  // Re-scatter un-dragged elements when the viewport size changes.
  let resizeTimer: number | undefined;
  window.addEventListener('resize', () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => { layout(); placeToggle(); }, 150);
  });
</script>
