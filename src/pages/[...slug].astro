---
import { CollectionEntry, getCollection } from 'astro:content';
import IndexLayout from '../layouts/IndexLayout.astro';
import moment from 'moment';

export async function getStaticPaths() {
	const posts = await getCollection('writings');
  return posts.map((post) => {
    const fullPath = `${moment(post.data.date).format('YYYY/MM/DD')}/${post.slug}`;

    return {
      params: { slug: fullPath },
      props: post,
    }
  });
}
type Props = CollectionEntry<'writings'>;

const post = Astro.props;
const { Content } = await post.render();

const description = post.data.description || post.body.split('\n').find(line => line.trim().length > 0)?.substring(0, 160) || post.data.title;
const formattedDate = moment(post.data.date).format('MMM DD, YYYY');
const isoDate = moment(post.data.date).toISOString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": description,
  "datePublished": isoDate,
  "dateModified": post.data.date_updated ? moment(post.data.date_updated).toISOString() : isoDate,
  "author": {
    "@type": "Person",
    "name": "Berkay Cubuk",
    "url": "https://berkaycubuk.com/about"
  },
  "url": `https://berkaycubuk.com/${moment(post.data.date).format('YYYY/MM/DD')}/${post.slug}/`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://berkaycubuk.com/${moment(post.data.date).format('YYYY/MM/DD')}/${post.slug}/`
  }
};
---
<IndexLayout title={post.data.title} description={description} type="article" jsonLd={jsonLd}>
  <div class="py-12">
    <a href="/writings" class="inline-flex items-center text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors mb-8">
      &larr; Back to writings
    </a>

    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3">{post.data.title}</h1>

    <time datetime={isoDate} class="text-sm text-[var(--color-text-tertiary)]">
      {formattedDate}
    </time>

    <article class="prose prose-lg max-w-none mt-8">
      <Content />
    </article>

    <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <a href="/writings" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
        &larr; All writings
      </a>
    </div>
  </div>
</IndexLayout>
