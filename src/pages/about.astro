---
import IndexLayout from '../layouts/IndexLayout.astro';
---
<IndexLayout title="About Berkay Cubuk" description="Software engineer working in blockchain industry. I write, tinker and build things.">
  <div class="py-12">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3">About me</h1>
    <p class="text-[var(--color-text-secondary)] mb-8">
      Hi, I'm Berkay and this is my space on the internet.
    </p>

    <div class="prose prose-lg max-w-none">
      <p>
        I'm a software engineer who currently works in the blockchain industry. I write, tinker and build things.
      </p>
      <p>
        Writing about yourself is always an issue :^) Will write more when I know myself better.
      </p>
    </div>

    <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <h2 class="text-xl font-semibold text-[var(--color-text)] mb-3">Working together</h2>
      <p class="text-[var(--color-text-secondary)] mb-5">
        If you have a problem worth a 20-minute conversation, grab a free slot on my calendar.
      </p>
      <a href="https://cal.com/berkaycubuk/discovery-call" target="_blank" rel="noopener noreferrer" class="inline-block px-5 py-2.5 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors text-sm">
        Book a call &rarr;
      </a>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)]">
      <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">Elsewhere</h2>
      <div class="flex flex-wrap gap-4">
        <a href="https://github.com/berkaycubuk" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
          GitHub &rarr;
        </a>
        <a href="https://x.com/brkycubuk" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
          X &rarr;
        </a>
        <a href="mailto:berkay@berkaycubuk.com" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
          Email &rarr;
        </a>
      </div>
    </div>
  </div>
</IndexLayout>
