---
import IndexLayout from '../layouts/IndexLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---
<IndexLayout title="Projects - Berkay's Space on the Internet" description="Projects and things I built. I tinker and build things in software engineering and blockchain.">
  <div class="py-12">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3">Projects</h1>
    <p class="text-[var(--color-text-secondary)] mb-8">
      Things I've built and am working on.
    </p>

    <div class="flex flex-col gap-4">
      <ProjectCard
        title="berkaycubuk.com"
        description="Website you currently see. I share my writings and projects here."
        tags={["Astro", "Tailwind CSS", "TypeScript"]}
        links={[{ label: "Source", href: "https://github.com/berkaycubuk/berkaycubuk.com" }]}
      />
    </div>
  </div>
</IndexLayout>
