---
const bookingUrl = "https://cal.com/berkaycubuk/discovery-call";
---
<section class="py-10 sm:py-14">
  <p class="text-[var(--color-accent)] font-medium mb-3">AI tools, shipped in weeks.</p>
  <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-[var(--color-text)] mb-4">
    I build small AI tools that solve problems.
  </h1>
  <p class="text-lg text-[var(--color-text-secondary)] max-w-lg mb-6">
    Bots, automation and single binary go projects.
  </p>
  <div class="flex flex-wrap gap-3">
    <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors text-sm">
      Book a 20-min call
    </a>
    <a href="#work" class="px-5 py-2.5 border border-[var(--color-border)] hover:border-[var(--color-text-tertiary)] text-[var(--color-text)] font-medium rounded-lg transition-colors text-sm">
      See recent work
    </a>
  </div>
</section>
